{
  "name": "smart-theme-switcher",
  "displayName": "smart-theme-switcher",
  "description": "Automatically changes VSCode theme based on time",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Smart Theme Switcher",
      "properties": {
        "smartTheme.morningTheme": {
          "type": "string",
          "default": "Default Light+",
          "description": "Theme used in the morning (6am - 12pm)"
        },
        "smartTheme.afternoonTheme": {
          "type": "string",
          "default": "Default Dark+",
          "description": "Theme used in the afternoon (12pm - 6pm)"
        },
        "smartTheme.nightTheme": {
          "type": "string",
          "default": "Abyss",
          "description": "Theme used at night (6pm - 6am)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
